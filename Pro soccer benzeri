<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Web Futbol Arenası</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #2c3e50;
            display: flex;
            flex-direction: column;
            align-items: center;
            font-family: Arial, sans-serif;
            color: white;
        }
        canvas {
            background-color: #27ae60;
            border: 5px solid #ecf0f1;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
            margin-top: 20px;
        }
        #scoreboard {
            font-size: 32px;
            font-weight: bold;
            margin-top: 20px;
        }
    </style>
</head>
<body>

    <div id="scoreboard">Kırmızı: 0 - Mavi: 0</div>
    <canvas id="gameCanvas" width="800" height="500"></canvas>

    <script>
        const canvas = document.getElementById("gameCanvas");
        const ctx = canvas.getContext("2d");
        const scoreElement = document.getElementById("scoreboard");

        let scores = { red: 0, blue: 0 };
        const friction = 0.96; // Sürtünme katsayısı

        // Klavye girişleri
        const keys = {};
        window.addEventListener("keydown", (e) => keys[e.key] = true);
        window.addEventListener("keyup", (e) => keys[e.key] = false);

        // Oyun Objeleri
        class Circle {
            constructor(x, y, radius, color, mass, isBall = false) {
                this.x = x;
                this.y = y;
                this.radius = radius;
                this.color = color;
                this.mass = mass;
                this.vx = 0;
                this.vy = 0;
                this.speed = 0.5;
                this.maxSpeed = isBall ? 10 : 4;
                this.isBall = isBall;
            }

            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                ctx.fillStyle = this.color;
                ctx.fill();
                ctx.closePath();
            }

            update() {
                this.vx *= friction;
                this.vy *= friction;

                // Hız sınırı
                let currentSpeed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);
                if (currentSpeed > this.maxSpeed) {
                    this.vx = (this.vx / currentSpeed) * this.maxSpeed;
                    this.vy = (this.vy / currentSpeed) * this.maxSpeed;
                }

                this.x += this.vx;
                this.y += this.vy;

                // Duvar çarpışmaları
                if (this.x - this.radius < 0) { this.x = this.radius; this.vx *= -1; }
                if (this.x + this.radius > canvas.width) { this.x = canvas.width - this.radius; this.vx *= -1; }
                
                // Kaleleri belirle (Y ekseni sınırları)
                let inGoalY = this.y > 150 && this.y < 350;

                if (this.y - this.radius < 0) { this.y = this.radius; this.vy *= -1; }
                if (this.y + this.radius > canvas.height) { this.y = canvas.height - this.radius; this.vy *= -1; }

                // Gol kontrolü (sadece top için)
                if (this.isBall) {
                    if (this.x - this.radius <= 5 && inGoalY) {
                        scores.blue++;
                        resetPositions();
                    } else if (this.x + this.radius >= canvas.width - 5 && inGoalY) {
                        scores.red++;
                        resetPositions();
                    }
                }
            }
        }

        const ball = new Circle(400, 250, 12, "white", 1, true);
        const player1 = new Circle(200, 250, 20, "#e74c3c", 2); // Kırmızı
        const player2 = new Circle(600, 250, 20, "#3498db", 2); // Mavi

        function resetPositions() {
            ball.x = 400; ball.y = 250; ball.vx = 0; ball.vy = 0;
            player1.x = 200; player1.y = 250; player1.vx = 0; player1.vy = 0;
            player2.x = 600; player2.y = 250; player2.vx = 0; player2.vy = 0;
            scoreElement.innerText = `Kırmızı: ${scores.red} - Mavi: ${scores.blue}`;
        }

        function checkCollision(c1, c2) {
            let dx = c2.x - c1.x;
            let dy = c2.y - c1.y;
            let distance = Math.sqrt(dx * dx + dy * dy);

            if (distance < c1.radius + c2.radius) {
                // Basit esnek çarpışma ve vektör itimi
                let angle = Math.atan2(dy, dx);
                let force = 1.5; 
                
                // Objeleri birbirinin içinden çıkar
                let overlap = (c1.radius + c2.radius) - distance;
                c2.x += Math.cos(angle) * overlap * 0.5;
                c2.y += Math.sin(angle) * overlap * 0.5;

                // Momentumu aktar
                c2.vx += Math.cos(angle) * force + (c1.vx * 0.5);
                c2.vy += Math.sin(angle) * force + (c1.vy * 0.5);
            }
        }

        function drawPitch() {
            ctx.strokeStyle = "rgba(255, 255, 255, 0.5)";
            ctx.lineWidth = 3;
            
            // Orta çizgi ve yuvarlak
            ctx.beginPath();
            ctx.moveTo(400, 0); ctx.lineTo(400, 500);
            ctx.stroke();
            ctx.beginPath();
            ctx.arc(400, 250, 60, 0, Math.PI * 2);
            ctx.stroke();

            // Kaleler
            ctx.fillStyle = "rgba(255, 255, 255, 0.3)";
            ctx.fillRect(0, 150, 40, 200); // Sol kale
            ctx.fillRect(760, 150, 40, 200); // Sağ kale
        }

        function gameLoop() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            drawPitch();

            // Player 1 (WASD) Hareket
            if (keys["w"]) player1.vy -= player1.speed;
            if (keys["s"]) player1.vy += player1.speed;
            if (keys["a"]) player1.vx -= player1.speed;
            if (keys["d"]) player1.vx += player1.speed;

            // Player 2 (Yön Tuşları) Hareket
            if (keys["ArrowUp"]) player2.vy -= player2.speed;
            if (keys["ArrowDown"]) player2.vy += player2.speed;
            if (keys["ArrowLeft"]) player2.vx -= player2.speed;
            if (keys["ArrowRight"]) player2.vx += player2.speed;

            // Çarpışmalar
            checkCollision(player1, ball);
            checkCollision(player2, ball);
            checkCollision(player1, player2);

            // Güncelle ve Çiz
            player1.update(); player1.draw();
            player2.update(); player2.draw();
            ball.update(); ball.draw();

            requestAnimationFrame(gameLoop);
        }

        gameLoop(); // Döngüyü başlat
    </script>
</body>
</html>

